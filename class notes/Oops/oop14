package pk;
class Person {
    String name;

    Person(String name) {
        this.name = name;
    }

    void showPersonInfo() {
        System.out.println("Name: " + name);
    }
}
// IS-A Relationship: Employee IS-A Person
class Employee extends Person {
    int empId;
    Company company;  // HAS-A Relationship

    Employee(String name, int empId, Company company) {
        super(name);  // call Person constructor
        this.empId = empId;
        this.company = company;
    }

    void showEmployeeInfo() {
        showPersonInfo();  // from Person class
        System.out.println("Employee ID: " + empId);
        company.showCompanyInfo();  // HAS-A
    }
}
class Company {
    String companyName;
    String location;

    Company(String companyName, String location) {
        this.companyName = companyName;
        this.location = location;
    }

    void showCompanyInfo() {
        System.out.println("Company: " + companyName);
        System.out.println("Location: " + location);
    }
}

public class EmployeeCompanyDemo {
    public static void main(String[] args) {
        Company c = new Company("LTLT Edutech Pvt. Ltd.", "Bhubaneswar");
        Employee e = new Employee("Jitendra Sahoo", 101, c);
        e.showEmployeeInfo();
    }
}



